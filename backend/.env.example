# ============================================
# CRM Backend - Variables de Entorno
# ============================================
# Copiar este archivo como .env y completar los valores

# --- Base de datos (PostgreSQL / Cloud SQL) ---
DB_HOST=
DB_PORT=6543
DB_USER=
DB_PASSWORD=
DB_NAME=

# --- JWT del CRM ---
JWT_SECRET=

# --- TiendaNube ---
TIENDANUBE_STORE_ID=
TIENDANUBE_ACCESS_TOKEN=

# --- Google Cloud Vision (OCR) ---
GOOGLE_CREDENTIALS_JSON=

# --- Google Sheets: tracking pedidos a_imprimir ---
# JSON de la service account con permiso Editor en el spreadsheet.
# Si falta cualquiera de estas dos vars, la integración queda en no-op.
GOOGLE_SHEETS_SA_KEY=
SHEETS_SPREADSHEET_ID=
SHEETS_TAB_NAME=Pedidos

# --- Sentry (error monitoring) ---
SENTRY_DSN=

# --- Server ---
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ============================================
# Frontend - Variables de Entorno (financial-crm/.env)
# ============================================
# VITE_API_URL=http://localhost:3000
