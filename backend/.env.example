# ============================================
# CRM Backend - Variables de Entorno
# ============================================
# Copiar este archivo como .env y completar los valores

# --- Base de datos (PostgreSQL / Cloud SQL) ---
DB_HOST=
DB_PORT=6543
DB_USER=
DB_PASSWORD=
DB_NAME=

# --- JWT del CRM ---
JWT_SECRET=

# --- TiendaNube ---
TIENDANUBE_STORE_ID=
TIENDANUBE_ACCESS_TOKEN=

# --- Google Cloud Vision (OCR) ---
GOOGLE_CREDENTIALS_JSON=

# --- Sentry (error monitoring) ---
SENTRY_DSN=

# --- Server ---
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ============================================
# Waspy - Integración WhatsApp
# ============================================

# URL base de la API de Waspy
# En desarrollo: http://localhost:4000
# En producción: https://tu-waspy-instance.com
WASPY_URL=http://localhost:4000

# Secret compartido para firmar JWTs que el CRM envía a Waspy
# Debe coincidir con el secret configurado en Waspy
WASPY_JWT_SECRET=

# UUID del tenant en Waspy (se obtiene al crear el tenant en Waspy)
WASPY_TENANT_ID=

# Issuer del JWT (identifica al CRM como emisor)
# Default: crm
WASPY_JWT_ISSUER=crm

# Audience del JWT (identifica a Waspy como receptor)
# Default: waspy
WASPY_JWT_AUDIENCE=waspy

# Tiempo de expiración del JWT
# Default: 1h
WASPY_JWT_EXPIRES_IN=1h

# ============================================
# Frontend - Variables de Entorno (financial-crm/.env)
# ============================================
# VITE_API_URL=http://localhost:3000
# VITE_WASPY_EMBED_URL=http://localhost:8080/embed/inbox
